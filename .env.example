# Copy this file to `.env` and fill in your key. The repo reads .env from the repo root.
# All LLM + embedding calls route through OpenRouter by default.

# --- required ---
OPENROUTER_API_KEY=your-openrouter-api-key-here

# --- embedding (optional; defaults shown) ---
# Embedding model + output dimensionality used to build/query the index.
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_DIMENSIONALITY=1536

# --- chat model / provider (optional; defaults shown) ---
# LLM_PROVIDER: "openrouter" (default) routes the chat model through OpenRouter.
#   Set to "deepseek" only to call the DeepSeek API directly (same weights, faster,
#   requires DEEPSEEK_API_KEY below).
LLM_PROVIDER=openrouter
# Chat model id when going through OpenRouter:
OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash

# --- DeepSeek-direct (only needed if LLM_PROVIDER=deepseek) ---
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
